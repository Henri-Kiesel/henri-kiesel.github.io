---
import '../styles/global.css';
import uiDe from '../data/ui.de.json';
import uiEn from '../data/ui.en.json';

type PageUi = typeof uiDe;

function welcomeDialogStrings(ui: PageUi) {
  return {
    welcomeTitle: ui.welcomeTitle,
    welcomeDialogAria: ui.welcomeDialogAria,
    welcomeLangLabel: ui.welcomeLangLabel,
    welcomeThemeLabel: ui.welcomeThemeLabel,
    welcomeThemeLight: ui.welcomeThemeLight,
    welcomeThemeDark: ui.welcomeThemeDark,
    welcomeThemeSystem: ui.welcomeThemeSystem,
    welcomeLocaleDe: ui.welcomeLocaleDe,
    welcomeLocaleEn: ui.welcomeLocaleEn,
    welcomeAdjustHint: ui.welcomeAdjustHint,
    welcomeCookieAlt: ui.welcomeCookieAlt,
    welcomeCookieCaption: ui.welcomeCookieCaption,
    welcomeSkip: ui.welcomeSkip,
    welcomeContinue: ui.welcomeContinue,
  };
}

const welcomeI18n = {
  de: welcomeDialogStrings(uiDe),
  en: welcomeDialogStrings(uiEn as PageUi),
};

interface Props {
  lang: 'de' | 'en';
  title: string;
  description: string;
  skipToContent: string;
  /** Vollständige kanonische URL dieser Seite (ohne trailing slash optional) */
  canonicalHref?: string;
  /** UI inkl. Willkommensdialog */
  pageUi?: PageUi;
  /** Gegenläufige URL derselben Seite für Sprachwechsel */
  welcomeAlternatePath?: string;
}

const { lang, title, description, skipToContent, canonicalHref, pageUi, welcomeAlternatePath } = Astro.props;
const siteUrl = Astro.site?.href ?? 'https://henri-kiesel.github.io/';
const base = siteUrl.endsWith('/') ? siteUrl.slice(0, -1) : siteUrl;
const urlDe = `${base}/`;
const urlEn = `${base}/en/`;
const canonical = canonicalHref ?? (lang === 'de' ? urlDe : urlEn);

const showWelcome = Boolean(pageUi && welcomeAlternatePath);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (function () {
        try {
          var k = 'site-theme';
          var s = localStorage.getItem(k);
          var t;
          if (s === 'light' || s === 'dark') t = s;
          else t = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" sizes="any" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="de" href={urlDe} />
    <link rel="alternate" hreflang="en" href={urlEn} />
    <link rel="alternate" hreflang="x-default" href={urlDe} />
  </head>
  <body>
    <a class="skip" href="#main">{skipToContent}</a>
    {
      showWelcome && pageUi && welcomeAlternatePath ? (
        <dialog
          class="welcome-dialog"
          lang={lang}
          aria-labelledby="welcome-dialog-title"
          aria-describedby="welcome-dialog-desc welcome-dialog-hint welcome-dialog-cookie-line"
          data-welcome-dialog
          data-welcome-alt-path={welcomeAlternatePath}
          data-welcome-page-lang={lang}
        >
          <script type="application/json" id="welcome-i18n-json" set:html={JSON.stringify(welcomeI18n)} />
          <div class="welcome-aurora" aria-hidden="true">
            <div class="welcome-aurora__band welcome-aurora__band--a"></div>
            <div class="welcome-aurora__band welcome-aurora__band--b"></div>
            <div class="welcome-aurora__band welcome-aurora__band--c"></div>
          </div>
          <div class="welcome-dialog-panel">
            <h2 class="welcome-dialog-title" id="welcome-dialog-title" data-welcome-copy="welcomeTitle">
              {pageUi.welcomeTitle}
            </h2>
            <p id="welcome-dialog-desc" class="visually-hidden" data-welcome-copy="welcomeDialogAria">
              {pageUi.welcomeDialogAria}
            </p>
            <fieldset class="welcome-fieldset">
              <legend class="welcome-legend" id="welcome-lang-legend" data-welcome-copy="welcomeLangLabel">
                {pageUi.welcomeLangLabel}
              </legend>
              <div class="welcome-options" role="radiogroup" aria-labelledby="welcome-lang-legend">
                <button
                  type="button"
                  class="welcome-choice-btn"
                  role="radio"
                  aria-checked="false"
                  tabindex="-1"
                  data-welcome-locale="de"
                  data-welcome-copy="welcomeLocaleDe">{pageUi.welcomeLocaleDe}</button>
                <button
                  type="button"
                  class="welcome-choice-btn"
                  role="radio"
                  aria-checked="false"
                  tabindex="-1"
                  data-welcome-locale="en"
                  data-welcome-copy="welcomeLocaleEn">{pageUi.welcomeLocaleEn}</button>
              </div>
            </fieldset>
            <fieldset class="welcome-fieldset">
              <legend class="welcome-legend" id="welcome-theme-legend" data-welcome-copy="welcomeThemeLabel">
                {pageUi.welcomeThemeLabel}
              </legend>
              <div class="welcome-options welcome-options--stack" role="radiogroup" aria-labelledby="welcome-theme-legend">
                <button
                  type="button"
                  class="welcome-choice-btn"
                  role="radio"
                  aria-checked="false"
                  tabindex="-1"
                  data-welcome-theme="light"
                  data-welcome-copy="welcomeThemeLight">{pageUi.welcomeThemeLight}</button>
                <button
                  type="button"
                  class="welcome-choice-btn"
                  role="radio"
                  aria-checked="false"
                  tabindex="-1"
                  data-welcome-theme="dark"
                  data-welcome-copy="welcomeThemeDark">{pageUi.welcomeThemeDark}</button>
                <button
                  type="button"
                  class="welcome-choice-btn"
                  role="radio"
                  aria-checked="false"
                  tabindex="-1"
                  data-welcome-theme="system"
                  data-welcome-copy="welcomeThemeSystem">{pageUi.welcomeThemeSystem}</button>
              </div>
            </fieldset>
            <p id="welcome-dialog-hint" class="welcome-hint" data-welcome-copy="welcomeAdjustHint">
              {pageUi.welcomeAdjustHint}
            </p>
            <div class="welcome-cookie-block">
              <img
                class="welcome-cookie-img"
                src="/assets/img/kr%C3%BCmelmonster_traurig.png"
                alt={pageUi.welcomeCookieAlt}
                data-welcome-copy="welcomeCookieAlt"
                loading="lazy"
                decoding="async"
              />
              <p id="welcome-dialog-cookie-line" class="welcome-cookie-caption" data-welcome-copy="welcomeCookieCaption">
                {pageUi.welcomeCookieCaption}
              </p>
            </div>
            <div class="welcome-actions">
              <button type="button" class="welcome-btn welcome-btn--secondary" data-welcome-skip data-welcome-copy="welcomeSkip">
                {pageUi.welcomeSkip}
              </button>
              <button type="button" class="welcome-btn welcome-btn--primary" data-welcome-continue data-welcome-copy="welcomeContinue">
                {pageUi.welcomeContinue}
              </button>
            </div>
          </div>
        </dialog>
      ) : null
    }
    <slot />
    {
      showWelcome ? (
        <script is:inline>
          (function () {
            var dlg = document.querySelector('[data-welcome-dialog]');
            if (!dlg || !(dlg instanceof HTMLDialogElement)) return;

            var altPath = dlg.getAttribute('data-welcome-alt-path') || '';
            var pageLang = dlg.getAttribute('data-welcome-page-lang') || 'de';

            var welcomePack = null;
            var jsonEl = document.getElementById('welcome-i18n-json');
            if (jsonEl && jsonEl.textContent) {
              try {
                welcomePack = JSON.parse(jsonEl.textContent);
              } catch (e0) {}
            }

            function applyWelcomeDialogCopy(locale) {
              if (!welcomePack) return;
              var pack = welcomePack[locale];
              if (!pack || typeof pack !== 'object') return;
              dlg.setAttribute('lang', locale === 'en' ? 'en' : 'de');
              dlg.querySelectorAll('[data-welcome-copy]').forEach(function (el) {
                var key = el.getAttribute('data-welcome-copy');
                if (!key || typeof pack[key] !== 'string') return;
                if (el.tagName === 'IMG') {
                  el.setAttribute('alt', pack[key]);
                } else {
                  el.textContent = pack[key];
                }
              });
            }

            function dismissed() {
              try {
                return localStorage.getItem('site-welcome-dismissed') === '1';
              } catch (e) {
                return false;
              }
            }

            function resolveTheme(stored) {
              if (stored === 'light' || stored === 'dark') return stored;
              return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
            }

            function syncThemeToggleButtons() {
              var theme = document.documentElement.getAttribute('data-theme') || 'dark';
              document.querySelectorAll('[data-theme-toggle]').forEach(function (btn) {
                var lLight = btn.getAttribute('data-label-light') || '';
                var lDark = btn.getAttribute('data-label-dark') || '';
                var next = theme === 'light' ? lDark : lLight;
                btn.setAttribute('aria-label', next);
                var txt = btn.querySelector('[data-theme-toggle-text]');
                if (txt) txt.textContent = next;
              });
            }

            function listLocaleBtns() {
              return Array.prototype.slice.call(dlg.querySelectorAll('[data-welcome-locale]'));
            }

            function listThemeBtns() {
              return Array.prototype.slice.call(dlg.querySelectorAll('[data-welcome-theme]'));
            }

            function setWelcomeLocale(value) {
              listLocaleBtns().forEach(function (b) {
                var v = b.getAttribute('data-welcome-locale') || '';
                var on = v === value;
                b.setAttribute('aria-checked', on ? 'true' : 'false');
                b.tabIndex = on ? 0 : -1;
              });
              if (value === 'de' || value === 'en') {
                applyWelcomeDialogCopy(value);
              }
            }

            function setWelcomeTheme(value) {
              listThemeBtns().forEach(function (b) {
                var v = b.getAttribute('data-welcome-theme') || '';
                var on = v === value;
                b.setAttribute('aria-checked', on ? 'true' : 'false');
                b.tabIndex = on ? 0 : -1;
              });
            }

            function selectAndFocus(btns, index) {
              var n = btns.length;
              if (!n) return;
              var i = ((index % n) + n) % n;
              var btn = btns[i];
              if (btn.hasAttribute('data-welcome-locale')) {
                setWelcomeLocale(btn.getAttribute('data-welcome-locale') || '');
              } else {
                setWelcomeTheme(btn.getAttribute('data-welcome-theme') || '');
              }
              btn.focus();
            }

            function initWelcomeChoices() {
              var locPref = null;
              var thPref = null;
              try {
                locPref = localStorage.getItem('preferred-locale');
              } catch (e) {}
              try {
                thPref = localStorage.getItem('site-theme');
              } catch (e2) {}
              var loc = locPref === 'en' || locPref === 'de' ? locPref : pageLang;
              var th = thPref === 'light' || thPref === 'dark' || thPref === 'system' ? thPref : 'system';
              setWelcomeLocale(loc);
              setWelcomeTheme(th);
            }

            function skip() {
              try {
                localStorage.setItem('site-welcome-dismissed', '1');
              } catch (e) {}
              dlg.close();
            }

            function onContinue() {
              var locEl = dlg.querySelector('[data-welcome-locale][aria-checked="true"]');
              var thEl = dlg.querySelector('[data-welcome-theme][aria-checked="true"]');
              var loc =
                locEl instanceof HTMLElement ? locEl.getAttribute('data-welcome-locale') || pageLang : pageLang;
              var th =
                thEl instanceof HTMLElement ? thEl.getAttribute('data-welcome-theme') || 'system' : 'system';
              try {
                localStorage.setItem('preferred-locale', loc);
                localStorage.setItem('site-theme', th);
                localStorage.setItem('site-welcome-dismissed', '1');
              } catch (e) {}
              var applied = resolveTheme(th);
              document.documentElement.setAttribute('data-theme', applied);
              syncThemeToggleButtons();
              dlg.close();
              if (loc !== pageLang && altPath) {
                window.location.href = altPath;
              }
            }

            dlg.addEventListener('cancel', function (e) {
              e.preventDefault();
              skip();
            });
            dlg.addEventListener('click', function (e) {
              var t = e.target;
              if (t === dlg) {
                skip();
                return;
              }
              if (!(t instanceof HTMLElement)) return;
              if (t.hasAttribute('data-welcome-locale')) {
                var lv = t.getAttribute('data-welcome-locale') || '';
                setWelcomeLocale(lv);
                t.focus();
                return;
              }
              if (t.hasAttribute('data-welcome-theme')) {
                var tv = t.getAttribute('data-welcome-theme') || '';
                setWelcomeTheme(tv);
                t.focus();
              }
            });

            dlg.addEventListener('keydown', function (e) {
              var t = e.target;
              if (!(t instanceof HTMLElement)) return;
              var locBtns = listLocaleBtns();
              var thBtns = listThemeBtns();
              var btns = t.hasAttribute('data-welcome-locale') ? locBtns : t.hasAttribute('data-welcome-theme') ? thBtns : null;
              if (!btns || !btns.length) return;
              var idx = btns.indexOf(t);
              if (idx < 0) return;
              var n = btns.length;
              if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
                e.preventDefault();
                selectAndFocus(btns, idx + 1);
              } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
                e.preventDefault();
                selectAndFocus(btns, idx - 1);
              } else if (e.key === 'Home') {
                e.preventDefault();
                selectAndFocus(btns, 0);
              } else if (e.key === 'End') {
                e.preventDefault();
                selectAndFocus(btns, n - 1);
              }
            });

            var skipBtn = dlg.querySelector('[data-welcome-skip]');
            var goBtn = dlg.querySelector('[data-welcome-continue]');
            if (skipBtn) skipBtn.addEventListener('click', skip);
            if (goBtn) goBtn.addEventListener('click', onContinue);

            initWelcomeChoices();

            function tryOpen() {
              if (dismissed()) return;
              if (typeof dlg.showModal === 'function') dlg.showModal();
            }
            if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', tryOpen);
            else tryOpen();
          })();
        </script>
      ) : null
    }
    <script is:inline>
      (function () {
        var dismissed = false;
        try {
          dismissed = localStorage.getItem('site-welcome-dismissed') === '1';
        } catch (e) {}
        if (dismissed) {
          var path = window.location.pathname;
          var pref = localStorage.getItem('preferred-locale');
          if (pref === 'en' && (path === '/' || path === '')) {
            window.location.replace('/en/');
          }
          if (pref === 'de' && (path === '/en' || path === '/en/')) {
            window.location.replace('/');
          }
        }
        document.querySelectorAll('[data-set-locale]').forEach(function (el) {
          el.addEventListener('click', function () {
            var v = el.getAttribute('data-set-locale');
            if (v) localStorage.setItem('preferred-locale', v);
          });
        });
      })();
    </script>
  </body>
</html>
