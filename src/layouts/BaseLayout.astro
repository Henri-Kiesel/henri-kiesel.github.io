---
import '../styles/global.css';

interface Props {
  lang: 'de' | 'en';
  title: string;
  description: string;
  skipToContent: string;
}

const { lang, title, description, skipToContent } = Astro.props;
const siteUrl = Astro.site?.href ?? 'https://henri-kiesel.github.io/';
const base = siteUrl.endsWith('/') ? siteUrl.slice(0, -1) : siteUrl;
const urlDe = `${base}/`;
const urlEn = `${base}/en/`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" sizes="any" />
    <link rel="canonical" href={lang === 'de' ? urlDe : urlEn} />
    <link rel="alternate" hreflang="de" href={urlDe} />
    <link rel="alternate" hreflang="en" href={urlEn} />
    <link rel="alternate" hreflang="x-default" href={urlDe} />
  </head>
  <body>
    <a class="skip" href="#main">{skipToContent}</a>
    <slot />
    <script is:inline>
      (function () {
        var path = window.location.pathname;
        var pref = localStorage.getItem('preferred-locale');
        if (pref === 'en' && (path === '/' || path === '')) {
          window.location.replace('/en/');
        }
        if (pref === 'de' && (path === '/en' || path === '/en/')) {
          window.location.replace('/');
        }
        document.querySelectorAll('[data-set-locale]').forEach(function (el) {
          el.addEventListener('click', function () {
            var v = el.getAttribute('data-set-locale');
            if (v) localStorage.setItem('preferred-locale', v);
          });
        });
      })();
    </script>
  </body>
</html>
