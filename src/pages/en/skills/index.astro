---
import SiteChrome from '../../../components/SiteChrome.astro';
import SkillsSection from '../../../components/SkillsSection.astro';
import site from '../../../data/site.json';
import skills from '../../../data/skills.en.json';
import ui from '../../../data/ui.en.json';
import type { SiteConfig } from '../../../types/site';
import type { SkillsDocument } from '../../../types/skills';

const typedSite = site as SiteConfig;
const typedSkills = skills as SkillsDocument;
const canonicalHref = new URL(Astro.url.pathname, Astro.site ?? new URL('https://henri-kiesel.github.io/')).href;
---

<SiteChrome
  lang="en"
  site={typedSite}
  ui={ui}
  activeNav="skills"
  title={ui.metaTitleSkills}
  description={ui.metaDescriptionSkills}
  canonicalHref={canonicalHref}
  alternatePath="/faehigkeiten/"
  nextLocale="de"
>
  <SkillsSection doc={typedSkills} />
</SiteChrome>
