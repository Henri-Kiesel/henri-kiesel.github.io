---
import SiteChrome from '../components/SiteChrome.astro';
import site from '../data/site.json';
import ui from '../data/ui.de.json';
import type { SiteConfig } from '../types/site';

const typedSite = site as SiteConfig;
const canonicalHref = new URL(Astro.url.pathname, Astro.site ?? new URL('https://henri-kiesel.github.io/')).href;
---

<SiteChrome
  lang="de"
  site={typedSite}
  ui={ui}
  activeNav="home"
  title={ui.metaTitleHome}
  description={ui.metaDescription}
  canonicalHref={canonicalHref}
  alternatePath="/en/"
  nextLocale="en"
/>
