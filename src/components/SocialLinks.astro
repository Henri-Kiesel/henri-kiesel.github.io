---
import type { SiteConfig } from '../types/site';

interface Props {
  site: SiteConfig;
  emailLabel: string;
  emailCopied: string;
}

const { site, emailLabel, emailCopied } = Astro.props;
const { social } = site;
const email = typeof site.email === 'string' ? site.email.trim() : '';

const labelMap: Record<string, string> = {
  github: 'GitHub',
  linkedin: 'LinkedIn',
  xing: 'Xing',
  orcid: 'ORCID',
  mastodon: 'Mastodon',
};

type IconKey = 'github' | 'linkedin';

const items = (Object.entries(social) as [string, string | undefined][])
  .filter(([, href]) => typeof href === 'string' && href.length > 0)
  .map(([key, href]) => ({
    key,
    href: href as string,
    label: labelMap[key] ?? key.charAt(0).toUpperCase() + key.slice(1),
    icon: (key === 'github' || key === 'linkedin' ? key : null) as IconKey | null,
  }));
---

{
  (items.length > 0 || email) && (
    <div class="social-row">
      {items.map(({ href, label, icon }) => (
        <a class="social-link" href={href} target="_blank" rel="noopener noreferrer">
          {icon === 'github' && (
            <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
            </svg>
          )}
          {icon === 'linkedin' && (
            <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          )}
          {label}
        </a>
      ))}
      {email ? (
        <button type="button" class="social-link social-email" data-copy-email={email} aria-label={emailLabel}>
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M4 6h16v12H4z" />
            <path d="M4 8l8 5 8-5" />
          </svg>
          {emailLabel}
        </button>
      ) : null}
      <span class="copy-toast" role="status" aria-live="polite" hidden data-email-toast>
        {emailCopied}
      </span>
    </div>
  )
}

<script define:vars={{ emailCopiedMsg: emailCopied }}>
  function initEmailCopy() {
    var btn = document.querySelector('[data-copy-email]');
    var toast = document.querySelector('[data-email-toast]');
    if (!(btn instanceof HTMLButtonElement) || !(toast instanceof HTMLElement)) return;
    var email = btn.getAttribute('data-copy-email') || '';
    var hideTimer = 0;
    btn.addEventListener('click', function () {
      function show() {
        toast.hidden = false;
        window.clearTimeout(hideTimer);
        hideTimer = window.setTimeout(function () {
          toast.hidden = true;
        }, 2200);
      }
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(email).then(show).catch(function () {
          toast.textContent = emailCopiedMsg;
          show();
        });
      } else {
        toast.textContent = emailCopiedMsg;
        show();
      }
    });
  }
  initEmailCopy();
</script>
